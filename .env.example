# توکن ربات از @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# آیدی یا یوزرنیم کانال (مثال: @my_channel یا -1001234567890)
TELEGRAM_CHANNEL_ID=@my_channel

# فاصله بین هر بررسی قیمت (ثانیه)
UPDATE_INTERVAL=60

# فقط وقتی قیمت عوض شد پیام بفرست (true/false)
SEND_ON_CHANGE_ONLY=true
